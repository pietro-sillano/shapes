Notebook[{
Cell["Standard form", "Text",
 CellChangeTimes->{{3.934869844038035*^9, 
  3.934869848789641*^9}},ExpressionUUID->"d0eff105-5a70-46d5-bef2-\
877d84dbc03c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"sol", "=", 
    RowBox[{"NDSolve", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"\[Psi]", "'''"}], "[", "s", "]"}], "==", 
          RowBox[{
           RowBox[{
            RowBox[{"-", 
             FractionBox["1", "2"]}], 
            RowBox[{
             RowBox[{
              RowBox[{"\[Psi]", "'"}], "[", "s", "]"}], "^", "3"}]}], "-", 
           RowBox[{
            FractionBox[
             RowBox[{"2", " ", 
              RowBox[{"Cos", "[", 
               RowBox[{"\[Psi]", "[", "s", "]"}], "]"}]}], 
             RowBox[{"r", "[", "s", "]"}]], " ", 
            RowBox[{
             RowBox[{"\[Psi]", "''"}], "[", "s", "]"}]}], "+", 
           FractionBox[
            RowBox[{"3", " ", 
             RowBox[{"Sin", "[", 
              RowBox[{"\[Psi]", "[", "s", "]"}], "]"}], " ", 
             RowBox[{
              RowBox[{
               RowBox[{"\[Psi]", "'"}], "[", "s", "]"}], "^", "2"}]}], 
            RowBox[{"2", 
             RowBox[{"r", "[", "s", "]"}]}]], "+", 
           RowBox[{
            FractionBox[
             RowBox[{
              RowBox[{"3", " ", 
               RowBox[{
                RowBox[{"Cos", "[", 
                 RowBox[{"\[Psi]", "[", "s", "]"}], "]"}], "^", "2"}]}], "-", 
              "1"}], 
             RowBox[{"2", " ", 
              RowBox[{
               RowBox[{"r", "[", "s", "]"}], "^", "2"}]}]], 
            RowBox[{
             RowBox[{"\[Psi]", "'"}], "[", "s", "]"}]}], "-", 
           RowBox[{
            FractionBox[
             RowBox[{
              RowBox[{
               RowBox[{"Cos", "[", 
                RowBox[{"\[Psi]", "[", "s", "]"}], "]"}], "^", "2"}], "+", 
              "1"}], 
             RowBox[{"2", " ", 
              RowBox[{
               RowBox[{"r", "[", "s", "]"}], "^", "3"}]}]], 
            RowBox[{"Sin", "[", 
             RowBox[{"\[Psi]", "[", "s", "]"}], "]"}]}], "+", 
           RowBox[{"\[Sigma]", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"\[Psi]", "'"}], "[", "s", "]"}], "+", 
              FractionBox[
               RowBox[{"Sin", "[", 
                RowBox[{"\[Psi]", "[", "s", "]"}], "]"}], 
               RowBox[{"r", "[", "s", "]"}]]}], ")"}]}]}]}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"r", "'"}], "[", "s", "]"}], "==", 
          RowBox[{"Cos", "[", 
           RowBox[{"\[Psi]", "[", "s", "]"}], "]"}]}], ",", 
         RowBox[{
          RowBox[{"r", "[", "0", "]"}], "==", "20"}], ",", 
         RowBox[{
          RowBox[{"\[Psi]", "[", "0", "]"}], "==", 
          RowBox[{
           RowBox[{"ArcSin", "[", 
            FractionBox["1", 
             RowBox[{"2", " ", "\[Pi]", "*", "20"}]], "]"}], "-", 
           "\[Epsilon]"}]}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"\[Psi]", "'"}], "[", "0", "]"}], "==", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"(", 
             RowBox[{"Sin", "[", 
              RowBox[{
               RowBox[{"ArcSin", "[", 
                RowBox[{"1", "/", 
                 RowBox[{"(", 
                  RowBox[{"2", " ", "\[Pi]", "*", "20"}], ")"}]}], "]"}], "-",
                "\[Epsilon]"}], "]"}], ")"}]}], "/", "20"}]}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"\[Psi]", "''"}], "[", "0", "]"}], "==", 
          RowBox[{
           RowBox[{
            RowBox[{"-", 
             FractionBox["1", "2"]}], 
            RowBox[{
             RowBox[{"(", 
              FractionBox[
               RowBox[{"Sin", "[", 
                RowBox[{
                 RowBox[{"ArcSin", "[", 
                  RowBox[{"1", "/", 
                   RowBox[{"(", 
                    RowBox[{"2", " ", "\[Pi]", "*", "20"}], ")"}]}], "]"}], 
                 "-", "\[Epsilon]"}], "]"}], "20"], ")"}], "^", "2"}], " ", 
            RowBox[{"Tan", "[", 
             RowBox[{
              RowBox[{"ArcSin", "[", 
               RowBox[{"1", "/", 
                RowBox[{"(", 
                 RowBox[{"2", " ", "\[Pi]", "*", "20"}], ")"}]}], "]"}], "-", 
              "\[Epsilon]"}], "]"}]}], "+", 
           RowBox[{
            FractionBox[
             RowBox[{"Cos", "[", 
              FractionBox[
               RowBox[{
                RowBox[{"ArcSin", "[", 
                 RowBox[{"1", "/", 
                  RowBox[{"(", 
                   RowBox[{"2", " ", "\[Pi]", "*", "20"}], ")"}]}], "]"}], 
                "-", "\[Epsilon]"}], "20"], "]"}], "20"], " ", 
            FractionBox["20", 
             RowBox[{"-", 
              RowBox[{"Sin", "[", 
               RowBox[{
                RowBox[{"ArcSin", "[", 
                 RowBox[{"1", "/", 
                  RowBox[{"(", 
                   RowBox[{"2", " ", "\[Pi]", "*", "20"}], ")"}]}], "]"}], 
                "-", "\[Epsilon]"}], "]"}]}]]}], "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              FractionBox[
               RowBox[{
                RowBox[{
                 RowBox[{"Cos", "[", 
                  FractionBox[
                   RowBox[{
                    RowBox[{"ArcSin", "[", 
                    RowBox[{"1", "/", 
                    RowBox[{"(", 
                    RowBox[{"2", " ", "\[Pi]", "*", "20"}], ")"}]}], "]"}], 
                    "-", "\[Epsilon]"}], "20"], "]"}], "^", "2"}], "+", "1"}],
                "800"], "+", "\[Sigma]"}], ")"}], 
            RowBox[{"Tan", "[", 
             RowBox[{
              RowBox[{"ArcSin", "[", 
               RowBox[{"1", "/", 
                RowBox[{"(", 
                 RowBox[{"2", " ", "\[Pi]", "*", "20"}], ")"}]}], "]"}], "-", 
              "\[Epsilon]"}], "]"}]}], " ", "-", " ", 
           FractionBox["f", "20"]}]}]}], "}"}], "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\[Epsilon]", "->", "0.0001"}], ",", 
         RowBox[{"f", "->", "0.001"}], ",", 
         RowBox[{"\[Sigma]", "->", 
          RowBox[{"1", "/", "2"}]}]}], "}"}]}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\[Psi]", "[", "s", "]"}], ",", 
        RowBox[{"r", "[", "s", "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"s", ",", 
        RowBox[{"-", "100"}], ",", "0"}], "}"}], ",", 
      RowBox[{"MaxStepSize", "->", "0.01"}], ",", 
      RowBox[{"AccuracyGoal", "->", "5"}], ",", 
      RowBox[{"PrecisionGoal", "->", "4"}]}], "]"}]}], ";"}], "\n", 
  "\[IndentingNewLine]"}]], "Input",
