 FormBox[
  RowBox[{
   FractionBox["dx", "dx"], "equation"}], TraditionalForm]], "Subtitle",
 FormatType->
  TraditionalForm,ExpressionUUID->"0821bf45-8d84-4028-bdc7-c8748bb4fa80"]], \
"Text",
