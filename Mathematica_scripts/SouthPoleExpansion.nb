     RowBox[{"psi2", "\[Rule]", "0"}], ",", 
     RowBox[{"U0", "\[Rule]", "0"}], ",", 
     RowBox[{"x1", "\[Rule]", "1"}], ",", 
     RowBox[{"x2", "\[Rule]", "0"}], ",", 
