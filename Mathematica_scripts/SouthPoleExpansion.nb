  3.925286864781219*^9}},ExpressionUUID->"675160b6-e03b-4131-b430-\
7010d0fbec5b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{"CoefficientList", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"cospsi", "[", "s", "]"}], "-", 
      RowBox[{"dxds", "[", "s", "]"}]}], ",", "s"}], "]"}], "==", "0"}], 
  "]"}]], "Input",
