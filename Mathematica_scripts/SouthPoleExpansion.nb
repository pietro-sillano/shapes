      RowBox[{"-", 
       FractionBox[
        RowBox[{"3", " ", 
         SuperscriptBox["psi2", "2"]}], 
        RowBox[{"4", " ", "U0"}]]}]}], ",", 
     RowBox[{"x1", "\[Rule]", "1"}], ",", 
     RowBox[{"x2", "\[Rule]", "0"}], ",", 
     RowBox[{"x3", "\[Rule]", 
      RowBox[{"-", 
       SuperscriptBox["U0", "2"]}]}], ",", 
     RowBox[{"x4", "\[Rule]", 
      RowBox[{"3", " ", "psi2", " ", "U0"}]}]}], "}"}], ",", 
   RowBox[{"{", 
