@article{erguderIdentifyingSystematicErrors2021,
  title = {Identifying Systematic Errors in a Power Spectral Analysis of Simulated Lipid Membranes},
  author = {Erg{\"u}der, Muhammed F. and Deserno, Markus},
  year = 2021,
  month = jun,
  journal = {The Journal of Chemical Physics},
  volume = {154},
