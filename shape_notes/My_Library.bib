@article{marrinkTwoDecadesMartini2023,
  title = {Two Decades of {{Martini}}: {{Better}} Beads, Broader Scope},
  shorttitle = {Two Decades of {{Martini}}},
  author = {Marrink, Siewert J. and Monticelli, Luca and Melo, Manuel N. and Alessandri, Riccardo and Tieleman, D. Peter and Souza, Paulo C. T.},
