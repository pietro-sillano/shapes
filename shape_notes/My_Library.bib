@article{steinkuhlerMolecularDynamicsSimulations2024,
  title = {Molecular {{Dynamics Simulations Show That Short Peptides Can Drive Synthetic Cell Division}} by {{Binding}} to the {{Inner Membrane Leaflet}}},
