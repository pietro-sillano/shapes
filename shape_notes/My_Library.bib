}

@article{bullerjahnOptimalEstimatesSelfdiffusion2020,
  title = {Optimal Estimates of Self-Diffusion Coefficients from Molecular Dynamics Simulations},
  author = {Bullerjahn, Jakob T{\'o}mas and Von B{\"u}low, S{\"o}ren and Hummer, Gerhard},
  year = 2020,
  month = jul,
  journal = {The Journal of Chemical Physics},
  volume = {153},
  number = {2},
  pages = {024116},
  issn = {0021-9606, 1089-7690},
  doi = {10.1063/5.0008312},
  url = {https://pubs.aip.org/jcp/article/153/2/024116/76262/Optimal-estimates-of-self-diffusion-coefficients},
  urldate = {2024-03-08},
  abstract = {Translational diffusion coefficients are routinely estimated from molecular dynamics simulations. Linear fits to mean squared displacement (MSD) curves have become the de facto standard, from simple liquids to complex biomacromolecules. Nonlinearities in MSD curves at short times are handled with a wide variety of ad hoc practices, such as partial and piece-wise fitting of the data. Here, we present a rigorous framework to obtain reliable estimates of the self-diffusion coefficient and its statistical uncertainty. We also assess in a quantitative manner if the observed dynamics is, indeed, diffusive. By accounting for correlations between MSD values at different times, we reduce the statistical uncertainty of the estimator and, thereby, increase its efficiency. With a Kolmogorov--Smirnov test, we check for possible anomalous diffusion. We provide an easy-to-use Python data analysis script for the estimation of self-diffusion coefficients. As an illustration, we apply the formalism to molecular dynamics simulation data of pure TIP4P-D water and a single ubiquitin protein. In another paper [S. von B\"ulow, J. T. Bullerjahn, and G. Hummer, J. Chem. Phys. 153, 021101 (2020)], we demonstrate its ability to recognize deviations from regular diffusion caused by systematic errors in a common trajectory ``unwrapping'' scheme that is implemented in popular simulation and visualization software.},
  langid = {english},
  annotation = {00054},
  file = {/home/pietro/Zotero/storage/JTGLWYCG/Bullerjahn et al. - 2020 - Optimal estimates of self-diffusion coefficients f.pdf}
}

