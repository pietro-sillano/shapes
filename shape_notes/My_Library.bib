@article{kumarMechanisticInsightsZRing2025,
  title = {Mechanistic {{Insights}} into {{Z-Ring Formation}} and {{Stability}}},
  author = {Kumar, Rajneesh and Srinivasan, Ramanujam and Chaudhuri, Debasish},
