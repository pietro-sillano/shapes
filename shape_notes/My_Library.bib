@article{foleyAsymmetricMembraneSticky2024,
  title = {Asymmetric Membrane ``Sticky Tape'' Enables Simultaneous Relaxation of Area and Curvature in Simulation},
  author = {Foley, Samuel L. and Deserno, Markus},
  year = 2024,
  month = feb,
  journal = {The Journal of Chemical Physics},
  volume = {160},
  number = {6},
  pages = {064111},
  issn = {0021-9606, 1089-7690},
  doi = {10.1063/5.0189771},
  url = {https://pubs.aip.org/jcp/article/160/6/064111/3263006/Asymmetric-membrane-sticky-tape-enables},
  urldate = {2025-01-28},
  abstract = {Biological lipid membranes are generally asymmetric, not only with respect to the composition of the two membrane leaflets but also with respect to the state of mechanical stress on the two sides. Computer simulations of such asymmetric membranes pose unique challenges with respect to the choice of boundary conditions and ensemble in which such simulations are to be carried out. Here, we demonstrate an alternative to the usual choice of fully periodic boundary conditions: The membrane is only periodic in one direction, with free edges running parallel to the single direction of periodicity. In order to maintain bilayer asymmetry under these conditions, nanoscale ``sticky tapes'' are adhered to the membrane edges in order to prevent lipid flip-flop across the otherwise open edge. In such semi-periodic simulations, the bilayer is free to choose both its area and mean curvature, allowing for minimization of the bilayer elastic free energy. We implement these principles in a highly coarse-grained model and show how even the simplest examples of such simulations can reveal useful membrane elastic properties, such as the location of the monolayer neutral surface.},
  langid = {english},
  file = {/home/pietro/Zotero/storage/U74GP5LH/Foley and Deserno - 2024 - Asymmetric membrane “sticky tape” enables simultaneous relaxation of area and curvature in simulatio.pdf;/home/pietro/Zotero/storage/WKIQ74SQ/Supp_Info_REVISED_The_Sticky_Tape_Paper.pdf}
}

