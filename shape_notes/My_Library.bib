@misc{brownIntegrativeModellingApproach2024,
  title = {An Integrative Modelling Approach to the Mitochondrial Cristae},
  author = {Brown, Chelsea M. and Westendorp, Marieke S. S. and {Zarmiento-Garcia}, Rubi and Stevens, Jan A. and Rouse, Sarah L. and Marrink, Siewert J. and Wassenaar, Tsjerk A.},
