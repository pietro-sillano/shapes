@article{bramkampStructureFunctionBacterial2012,
  title = {Structure and Function of Bacterial Dynamin-like Proteins},
  author = {Bramkamp, Marc},
  year = 2012,
  month = nov,
  journal = {bchm},
  volume = {393},
